/* 底部按钮外层容器：使用 flex 布局实现完美对齐 */
.footer-btns {
  display: flex;
  flex-direction: row;        /* 横向排列 */
  justify-content: space-between; /* 两端对齐，或者用 space-around */
  align-items: center;        /* 垂直绝对居中（核心！） */
  padding: 40rpx 60rpx;
  background-color: #ffffff;
  margin-top: 40rpx;
  padding-bottom: env(safe-area-inset-bottom); /* 适配苹果底部小黑条 */
}

/* 取消按钮样式 */
.cancel-btn {
  font-size: 32rpx;
  color: #666666;
  padding: 20rpx 40rpx; /* 增加点击区域 */
}

/* 确认添加按钮样式 */
.confirm-btn {
  margin: 0 !important; /* 清除小程序 button 自带的乱七八糟的外边距 */
  width: 60% !important; /* 调整绿色按钮的宽度 */
  border-radius: 50rpx;
  font-size: 32rpx;
}

