.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  display: flex;
  align-items: center;
  background-color: #07c160;
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.plant-list {
  min-height: 200rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}

.plant-item {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

.plant-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.plant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.plant-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.plant-species {
  font-size: 28rpx;
  color: #666;
}

.plant-date {
  font-size: 24rpx;
  color: #999;
}

.delete-btn {
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 10;
  opacity: 0.7;
}

.delete-btn:active {
  opacity: 1;
} 