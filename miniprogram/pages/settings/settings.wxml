<!--pages/settings/settings.wxml-->
<view class="container">
  <view class="settings-header">
    <text class="title">设置</text>
  </view>

  <view class="settings-list">
    <!-- 账号设置 -->
    <view class="settings-group">
      <view class="group-title">账号设置</view>
      <view class="settings-item" bindtap="navigateToProfile">
        <text class="item-label">个人资料</text>
        <view class="item-right">
          <text class="item-value">{{userInfo.nickName || '未设置'}}</text>
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="settings-item" bindtap="navigateToAddress">
        <text class="item-label">收货地址</text>
        <view class="item-right">
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <!-- 通用设置 -->
    <view class="settings-group">
      <view class="group-title">通用设置</view>
      <view class="settings-item">
        <text class="item-label">消息通知</text>
        <switch checked="{{settings.notifications}}" bindchange="toggleNotifications"></switch>
      </view>
      <view class="settings-item">
        <text class="item-label">自动播放视频</text>
        <switch checked="{{settings.autoPlay}}" bindchange="toggleAutoPlay"></switch>
      </view>
      <view class="settings-item">
        <text class="item-label">清除缓存</text>
        <view class="item-right">
          <text class="item-value">{{cacheSize}}</text>
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <!-- 隐私设置 -->
    <view class="settings-group">
      <view class="group-title">隐私设置</view>
      <view class="settings-item">
        <text class="item-label">浏览历史</text>
        <switch checked="{{settings.browseHistory}}" bindchange="toggleBrowseHistory"></switch>
      </view>
      <view class="settings-item">
        <text class="item-label">搜索历史</text>
        <switch checked="{{settings.searchHistory}}" bindchange="toggleSearchHistory"></switch>
      </view>
    </view>

    <!-- 其他设置 -->
    <view class="settings-group">
      <view class="group-title">其他</view>
      <view class="settings-item" bindtap="showAbout">
        <text class="item-label">关于我们</text>
        <view class="item-right">
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="settings-item" bindtap="showFeedback">
        <text class="item-label">意见反馈</text>
        <view class="item-right">
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="settings-item" bindtap="checkUpdate">
        <text class="item-label">检查更新</text>
        <view class="item-right">
          <text class="item-value">当前版本 {{version}}</text>
          <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮
  <view class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">
    退出登录
  </view> -->
</view> 