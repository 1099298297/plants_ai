<view class="container">
  <view class="user-info">
    <!-- 已登录状态 -->
    <block wx:if="{{isLoggedIn}}">
      <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" style="padding:0; width:120rpx; height:120rpx; border-radius:50%; flex-shrink:0;">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/icons/default-avatar.png'}}" mode="aspectFill" style="width:100%; height:100%; border-radius:50%;"></image>
      </button>
      
      <view class="user-detail">
        <input 
          type="nickname" 
          class="nickname-input" 
          placeholder-style="color: rgba(255,255,255,0.8);" 
          value="{{userInfo.nickName}}" 
          placeholder="点击修改微信昵称" 
          bindblur="onInputNickname" 
        />
        <text class="edit-tip">点击头像和昵称可更新信息</text>
      </view>
    </block>

    <!-- 未登录状态 -->
    <!-- 未登录状态 -->
    <block wx:else>
      <view class="avatar-wrapper" style="border: none; width:120rpx; height:120rpx; border-radius:50%;">
        <image class="avatar" src="/images/icons/default-avatar.png" mode="aspectFill" style="width:100%; height:100%; border-radius:50%;"></image>
      </view>
      <!-- 修复：通过 flex-start 让整体左对齐，给按钮固定行高和 flex 居中 -->
      <view class="user-detail" style="display: flex; flex-direction: column; justify-content: center; align-items: flex-start; margin-left: 30rpx;">
        <text class="nickname" style="font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 16rpx;">未登录</text>
        <button class="login-btn" bindtap="login" style="margin: 0; padding: 0; width: 200rpx; height: 56rpx; border-radius: 28rpx; font-size: 26rpx; background-color: #fff; color: #07c160; display: flex; justify-content: center; align-items: center;">去授权登录</button>
      </view>
    </block>
  </view>

  <view class="menu-list">
    <view class="menu-group">
      <view class="menu-item" bindtap="navigateToOrders">
        <image class="menu-icon" src="/images/icons/order.png" mode="aspectFit"></image>
        <text class="menu-text">我的订单</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="navigateToCart">
        <image class="menu-icon" src="/images/icons/cart.png" mode="aspectFit"></image>
        <text class="menu-text">购物车</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="navigateToFavorites">
        <image class="menu-icon" src="/images/icons/heart-filled.png" mode="aspectFit"></image>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="menu-group">
      <view class="menu-item" bindtap="navigateToAddress">
        <image class="menu-icon" src="/images/icons/address.png" mode="aspectFit"></image>
        <text class="menu-text">收货地址</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="navigateToHistory">
        <image class="menu-icon" src="/images/icons/history.png" mode="aspectFit"></image>
        <text class="menu-text">浏览历史</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="menu-group">
      <view class="menu-item" bindtap="navigateToSettings">
        <image class="menu-icon" src="/images/icons/settings.png" mode="aspectFit"></image>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" type="warn" bindtap="handleLogout" style="width: 80%; margin-top: 40rpx; border-radius: 50rpx;">退出登录</button>
  </view>
</view>