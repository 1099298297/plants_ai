.container {
  padding: 40rpx 30rpx; /* 稍微增加内边距，让两边留白更舒服 */
  background-color: #f5f5f5;
  min-height: 100vh;
  width: 100vw; /* 确保宽度只占满屏幕 */
  box-sizing: border-box; /* 极其重要：防止 padding 撑破屏幕宽度导致不居中！ */
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}

.image-container {
  width: 100%;
  height: 500rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

/* ================== 按钮组完美居中修复 ================== */
.button-group {
  display: flex;
  flex-direction: column;
  align-items: center; /* 强行垂直列的水平居中 */
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.btn {
  width: 100% !important; /* 占满父容器 */
  height: 90rpx !important;
  line-height: 90rpx !important;
  border-radius: 50rpx !important;
  font-size: 32rpx !important;
  font-weight: normal; /* 去除某些手机默认粗体 */
  margin: 0 0 30rpx 0 !important; /* 用 margin-bottom 替代 gap，兼容性完美 */
  padding: 0 !important; /* 彻底清除微信按钮自带的 padding 毒瘤 */
  box-sizing: border-box !important;
  text-align: center;
}

.btn:last-child {
  margin-bottom: 0 !important; /* 最后一个按钮不需要底部间距 */
}
/* ======================================================= */

.btn-text {
  font-size: 32rpx;
}

.result-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.result-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.result-text {
  white-space: pre-wrap;
  word-break: break-all;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
}

.loading-text {
  color: #666;
  font-size: 28rpx;
}

/* 商品推荐区域样式 */
.product-recommendation {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.recommendation-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.recommendation-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.toggle-icon {
  display: flex;
  align-items: center;
  transition: transform 0.3s ease;
}

.toggle-icon.expanded {
  transform: rotate(180deg);
}

.arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s ease;
}

.recommendation-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.recommendation-content.expanded {
  max-height: 1000rpx;
}

.product-list {
  padding: 0 20rpx;
}

.product-item {
  display: flex;
  padding: 30rpx 10rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background-color: #f5f5f5; /* 给未加载出来的图片加个底色 */
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.product-price {
  font-size: 34rpx;
  color: #e64340;
  font-weight: bold;
}

.view-more {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.view-more .icon-arrow-right {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* ================= 新增：一键添加植物按钮样式 ================= */
.add-btn-wrapper {
  margin-top: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.add-plant-btn {
  width: 100% !important;
  background-color: #00B85C; 
  color: #ffffff;
  border-radius: 50rpx !important;
  font-size: 32rpx !important;
  font-weight: normal;
  padding: 20rpx 0 !important;
  line-height: 1.5 !important;
}
/* ========================================================== */