.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  box-sizing: border-box;
}

.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  /* 去掉这里的 padding，放到内部去，防止整体宽度溢出 */
  box-sizing: border-box;
}

.chat-content {
  flex: 1;
  margin-bottom: 20rpx;
}

.chat-list {
  padding: 20rpx;
}

.chat-item {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
}

.chat-item.user {
  align-items: flex-end;
}

.chat-item.bot {
  align-items: flex-start;
}

.message {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 10rpx;
  word-break: break-all;
}

.user .message {
  background: #007AFF;
  color: white;
}

.bot .message {
  background: white;
  color: #333;
}

/* ================== 输入区与按钮核心修改 ================== */
.input-area {
  background: white;
  padding: 30rpx 40rpx; /* 稍微增加左右内边距，让整体更收拢居中 */
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom); /* 适配苹果底部小黑条 */
  box-sizing: border-box;
  width: 100%;
}

.text-input {
  background: #f5f5f5;
  padding: 0 30rpx;
  height: 80rpx; /* 给输入框固定高度 */
  border-radius: 10rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 按钮组外层容器 */
.button-group {
  display: flex !important;
  flex-direction: row !important;
  justify-content: space-between !important; /* 让两个按钮分居两端，自动流出完美间隙 */
  align-items: center !important;
  width: 100%;
}

/* 强行洗掉微信 Button 的毒瘤默认样式 */
.send-btn, .voice-btn {
  margin: 0 !important;    /* 核心：干掉自带外边距 */
  padding: 0 !important;   /* 核心：干掉自带内边距 */
  width: 47% !important;   /* 核心：每个各占 47%，剩下的 6% 是它们中间的完美间距 */
  height: 80rpx !important;
  line-height: 80rpx !important; /* 文字绝对垂直居中 */
  text-align: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: normal; /* 覆盖某些安卓机的粗体默认值 */
}

.send-btn {
  background: #007AFF !important;
  color: white !important;
}

.voice-btn {
  background: #f5f5f5 !important;
  color: #333 !important;
}

.voice-btn.recording {
  background: #ff4d4f !important;
  color: white !important;
}
/* ========================================================= */

/* 下面是你原有的悬浮录音按钮代码（保留不动） */
.record-section {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.record-btn.recording {
  background-color: #ff4d4f;
  transform: scale(1.1);
}

.record-tip {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}