.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-status {
  background: #fff;
  text-align: center;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.status-text.pending {
  color: #ff9800;
}

.status-text.paid {
  color: #4caf50;
}

.tip {
  font-size: 26rpx;
  color: #999;
}

/* -------- 地址样式 新增 -------- */
.address-card {
  line-height: 1.6;
}
.address-info .name {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}
.address-info .phone {
  font-size: 26rpx;
  color: #666;
}
.address-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.goods-info text {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.total {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
}

.total .price {
  color: #e64340;
}

.pay-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.pay-btn {
  background: #4caf50;
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spec {
  font-size: 24rpx;
  color: #999;
  margin: 4rpx 0;
  display: block;
}