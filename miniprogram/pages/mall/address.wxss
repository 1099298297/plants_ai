/* pages/mall/address.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.address-header {
  padding: 20rpx 0;
  text-align: center;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.address-list {
  background-color: #fff;
  border-radius: 12rpx;
}

.address-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.address-item:last-child {
  border-bottom: none;
}

.address-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.address-info {
  flex: 1;
  margin-right: 20rpx;
}

.contact-info {
  margin-bottom: 10rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #666;
}

.default-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 24rpx;
  border-radius: 4rpx;
  margin-left: 20rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

.address-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 6rpx;
}

.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-address image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-address text {
  color: #999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.add-btn {
  width: 100%;
  height: 88rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}