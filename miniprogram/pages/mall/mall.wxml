<view class="container">
  <view class="search-bar">
  <view class="search-input-wrap">
    <image class="search-icon" src="/images/icons/search.png" mode="aspectFit"></image>
    <input type="text" 
           placeholder="搜索商品" 
           value="{{searchValue}}"
           bindinput="onSearchInput"
           bindfocus="onSearchFocus"
           bindconfirm="onSearchConfirm"
           confirm-type="search"/>
    <image wx:if="{{searchValue}}" 
           class="clear-icon" 
           src="/images/icons/clear.png" 
           mode="aspectFit"
           bindtap="clearSearch"></image>

    <!-- 框内搜索按钮（美观版） -->
    <view class="search-btn" bindtap="onSearchConfirm">
      搜索
    </view>
  </view>
</view>
  <view class="search-suggestions" wx:if="{{showSuggestions}}">
    <view class="suggestion-list" wx:if="{{suggestions.length > 0}}">
      <view class="suggestion-item" 
            wx:for="{{suggestions}}" 
            wx:key="*this"
            bindtap="selectSuggestion"
            data-suggestion="{{item}}">
        <image class="suggestion-icon" src="/images/icons/search.png" mode="aspectFit"></image>
        <text>{{item}}</text>
      </view>
    </view>
    
    <view class="search-history" wx:if="{{searchHistory.length > 0 && !suggestions.length}}">
      <view class="history-header">
        <text>搜索历史</text>
        <image class="clear-history" 
               src="/images/icons/delete.png" 
               mode="aspectFit"
               bindtap="clearSearchHistory"></image>
      </view>
      <view class="history-list">
        <view class="history-item" 
              wx:for="{{searchHistory}}" 
              wx:key="*this"
              bindtap="selectSuggestion"
              data-suggestion="{{item}}">
          <image class="history-icon" src="/images/icons/history.png" mode="aspectFit"></image>
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="category-list">
    <view class="category-item {{currentCategory === 'all' ? 'active' : ''}}" 
          bindtap="switchCategory" data-category="all">全部</view>
    <view class="category-item {{currentCategory === 'plants' ? 'active' : ''}}" 
          bindtap="switchCategory" data-category="plants">植物</view>
    <view class="category-item {{currentCategory === 'tools' ? 'active' : ''}}" 
          bindtap="switchCategory" data-category="tools">工具</view>
  </view>

  <view class="content-area">
    <view class="loading-container" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text>搜索中...</text>
    </view>
    <view class="product-list">
      <view class="product-item" 
            wx:for="{{products}}" 
            wx:key="id" 
            bindtap="navigateToDetail" 
            data-id="{{item.id}}"
            data-douyinlink="{{item.douyinLink}}">
        <image src="{{item.image}}" mode="aspectFill"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">¥{{item.price}}</text>
          <text wx:if="{{item.douyinLink}}" class="jump-tag">抖音选购</text>
        </view>
      </view>
      </view>

      <!-- 无数据提示 -->
      <view class="no-result" wx:if="{{!isLoading && products.length == 0}}">
      <image src="/images/icons/no-result.png" mode="aspectFit"></image>
      <text>未找到相关商品</text>
      <text class="no-result-tip">换个关键词试试吧</text>
      </view>
  </view>
</view>