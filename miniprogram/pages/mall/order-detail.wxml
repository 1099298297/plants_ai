<view class="container">
  <!-- 订单状态 -->
  <view class="order-status">
    <text class="status-text {{order.status}}">{{order.statusText}}</text>
    <text class="tip" wx:if="{{order.status === 'pending'}}">请尽快完成支付</text>
  </view>

  <!-- 收货地址（新增，样式完全统一） -->
  <view class="address-card card" wx:if="{{order.address}}">
    <view class="section-title">收货地址</view>
    <view class="address-info">
      <text class="name">{{order.address.name}}</text>
      <text class="phone">{{order.address.phone}}</text>
      <text class="address-detail">{{order.address.province}}{{order.address.city}}{{order.address.district}}{{order.address.detail}}</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info card">
    <view class="info-item">
      <text>订单编号</text>
      <text>{{order._id}}</text>
    </view>
    <view class="info-item">
      <text>创建时间</text>
      <text>{{order.createTimeText}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-section card">
    <view class="section-title">商品信息</view>
    <view class="goods-item" wx:for="{{order.items}}" wx:key="productId">
      <image src="{{item.image}}" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="name">{{item.name}}</text>
        <text class="spec" wx:if="{{item.spec}}">{{item.spec}}</text>
        <text class="price">¥{{item.price}}</text>
        <text class="num">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 总价 -->
  <view class="total card">
    <text>订单总价</text>
    <text class="price">¥{{order.totalPrice}}</text>
  </view>

  <!-- 支付按钮（仅待支付显示） -->
  <view class="pay-bottom" wx:if="{{order.status === 'pending'}}">
    <button class="pay-btn" bindtap="goToPay">立即支付</button>
  </view>
</view>