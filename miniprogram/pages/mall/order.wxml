<view class="container">
  <!-- 顶部标题 -->
  <view class="order-header">
    <text class="title">我的订单</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      <!-- 订单号 + 状态 -->
      <view class="order-top">
        <text>订单号：{{item.shortId}} </text>
        <text class="status {{item.status}}">{{item.statusText}}</text>
      </view>

      <!-- 商品列表 -->
      <view class="goods-container">
        <view class="goods-item" wx:for="{{item.items}}" wx:key="productId">
          <image src="{{item.image}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="name">{{item.name}}</text>
            <text class="price">¥{{item.price}}</text>
            <text class="num">x{{item.quantity}}</text>
          </view>
        </view>
      </view>

      <!-- 总价 + 操作按钮 -->
      <view class="order-bottom">
        <view class="total-info">
          <text>共{{item.items.length}}件</text>
          <text class="total-price">实付：¥{{item.fixedPrice}}</text>
        </view>
        <view class="btn-scale">
          <button wx:if="{{item.status === 'pending'}}" class="pay-btn" catchtap="goToPay" data-id="{{item._id}}">去支付</button>
          <button wx:if="{{item.status === 'pending'}}" class="cancel-btn" catchtap="cancelOrder" data-id="{{item._id}}">取消订单</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空订单 -->
  <view class="empty-order" wx:if="{{orderList.length === 0}}">
    <text>暂无订单</text>
  </view>
</view>