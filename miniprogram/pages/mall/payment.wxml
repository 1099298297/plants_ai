<view class="container">
  <view class="pay-box">
    <view class="title">订单支付</view>

    <view class="order-info">
      <view class="item">
        <text>订单编号</text>
        <text>{{order.shortId}}</text>
      </view>
      <view class="item">
        <text>订单状态</text>
        <text class="status pending">{{order.statusText}}</text>
      </view>
      <view class="item price-item">
        <text>支付金额</text>
        <text class="price">¥{{order.fixedPrice}}</text>
      </view>
    </view>

    <view class="pay-way">
      <view class="way-item active">
        <text>微信支付</text>
      </view>
    </view>

    <button class="pay-btn" bindtap="toPay">确认支付</button>
  </view>
</view>