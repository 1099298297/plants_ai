<view class="container">
  <view class="payment-header">
    <text class="title">订单支付</text>
  </view>

  <view class="payment-info">
    <view class="amount">
      <text class="label">支付金额</text>
      <text class="value">¥{{order.totalPrice}}</text>
    </view>
    <view class="order-info">
      <text class="order-id">订单号：{{order.id}}</text>
      <text class="order-time">创建时间：{{order.createTime}}</text>
    </view>
  </view>

  <view class="payment-methods">
    <view class="method-title">选择支付方式</view>
    <view class="method-list">
      <view class="method-item {{selectedMethod === 'wechat' ? 'selected' : ''}}" 
            bindtap="selectMethod" data-method="wechat">
        <image class="method-icon" src="/images/icons/wechat-pay.png" mode="aspectFit"></image>
        <text class="method-name">微信支付</text>
        <icon class="check-icon" type="success" size="20" wx:if="{{selectedMethod === 'wechat'}}"/>
      </view>
      <view class="method-item {{selectedMethod === 'alipay' ? 'selected' : ''}}" 
            bindtap="selectMethod" data-method="alipay">
        <image class="method-icon" src="/images/icons/alipay.png" mode="aspectFit"></image>
        <text class="method-name">支付宝</text>
        <icon class="check-icon" type="success" size="20" wx:if="{{selectedMethod === 'alipay'}}"/>
      </view>
    </view>
  </view>

  <view class="payment-actions">
    <button class="pay-btn" bindtap="handlePayment" disabled="{{!selectedMethod}}">
      立即支付
    </button>
    <button class="cancel-btn" bindtap="cancelPayment">取消支付</button>
  </view>

  <view class="payment-tips">
    <text>支付完成后，请等待商家发货</text>
  </view>
</view> 