<view class="container">
  <swiper class="product-swiper" indicator-dots="true" autoplay="true" interval="3000" duration="500">
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" class="slide-image"></image>
    </swiper-item>
  </swiper>

  <view class="product-info">
    <view class="product-name">{{product.name}}</view>
    <view class="product-price">¥{{product.price}}</view>
    <view class="product-description">{{product.description}}</view>
  </view>

  <view class="product-details">
    <view class="section-title">商品详情</view>
    <view class="detail-item" wx:for="{{product.details}}" wx:key="label">
      <text class="label">{{item.label}}</text>
      <text class="value">{{item.value}}</text>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-item" bindtap="toggleFavorite">
      <image src="{{isFavorite ? '/images/icons/heart-filled.png' : '/images/icons/heart.png'}}" mode="aspectFit"></image>
      <text>收藏</text>
    </view>
    <view class="action-item" bindtap="showSpecModal">
      <image src="/images/icons/cart.png" mode="aspectFit"></image>
      <text>加入购物车</text>
    </view>
    <button class="buy-now" bindtap="showBuyModal">立即购买</button>
  </view>
</view>

<view class="spec-modal" wx:if="{{showModal}}" bindtap="closeModal">
  <view class="spec-popup" catchtap="noop">
    <view class="spec-header">
      <text>选择规格</text>
      <text bindtap="closeModal">×</text>
    </view>

    <!-- 规格选择区域（你原来的，不动） -->
    <view class="spec-group" wx:for="{{specKeys}}" wx:key="*this">
      <view class="spec-title">{{item}}</view>
      <view class="spec-items">
        <text 
          wx:for="{{product.specs[item]}}" 
          wx:for-item="val"
          wx:key="*this"
          class="spec-item {{selectedSpecs[item] === val ? 'active' : ''}}"
          data-key="{{item}}"
          data-val="{{val}}"
          bindtap="selectSpecItem"
        >{{val}}</text>
      </view>
    </view>

    <!-- ====================== -->
    <!-- ✅ 新增：数量选择器 + 库存显示 -->
    <!-- ====================== -->
    <view class="quantity-section">
      <text class="q-label">购买数量</text>
      <view class="q-control">
        <text class="q-btn" bindtap="cutQty">-</text>
        <text class="q-num">{{qty}}</text>
        <text class="q-btn" bindtap="addQty">+</text>
      </view>
      <text class="stock-tip" wx:if="{{product.stock > 0}}">库存：{{product.stock}}件</text>
    </view>

    <button class="confirm" bindtap="confirmSpec">确认</button>
  </view>
</view>