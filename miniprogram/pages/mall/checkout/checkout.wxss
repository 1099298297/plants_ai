.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 地址 */
.address-card {
  position: relative;
}

.address-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.address-card .name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.address-card .phone {
  font-size: 26rpx;
  color: #666;
}

.default-tag {
  background: #07c160;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.no-address-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 商品 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  padding: 0;
}

.goods-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-info .name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.goods-info .price {
  font-size: 26rpx;
  color: #e64340;
  display: block;
}

.goods-info .num {
  font-size: 26rpx;
  color: #666;
}

/* 总价 */
.total-card {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
}

.total-card .price {
  color: #e64340;
}

/* 底部按钮 */
.pay-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.pay-btn {
  background: #4caf50;
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 规格样式 */
.spec {
  font-size: 24rpx;
  color: #999;
  margin: 4rpx 0;
  display: block;
}