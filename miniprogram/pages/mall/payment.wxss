.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.payment-header {
  padding: 20rpx 0;
  text-align: center;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.payment-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.amount {
  text-align: center;
  margin-bottom: 30rpx;
}

.amount .label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.amount .value {
  font-size: 48rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.order-info {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.order-id, .order-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.payment-methods {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.method-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
}

.method-item.selected {
  border-color: #07c160;
  background-color: #f0f9eb;
}

.method-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.check-icon {
  color: #07c160;
}

.payment-actions {
  padding: 40rpx 20rpx;
}

.pay-btn {
  width: 100%;
  height: 88rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.pay-btn[disabled] {
  background-color: #ccc;
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.payment-tips {
  text-align: center;
  padding: 20rpx;
}

.payment-tips text {
  font-size: 24rpx;
  color: #999;
} 