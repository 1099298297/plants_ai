.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.pay-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.order-info {
  margin-bottom: 40rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item {
  border-bottom: none;
  margin-top: 10rpx;
}

.status {
  color: #ff9800;
  font-weight: bold;
}

.price {
  color: #e64340;
  font-size: 36rpx;
  font-weight: bold;
}

.pay-way {
  margin-bottom: 60rpx;
}

.way-item {
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.way-item.active {
  background: #e6f7e6;
  border: 1rpx solid #4caf50;
}

.pay-btn {
  background: #4caf50;
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}