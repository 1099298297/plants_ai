.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.order-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-top text {
  font-size: 26rpx;
  color: #666;
}

.status {
  font-weight: bold;
}

.status.pending {
  color: #FF9800;
}

.status.paid {
  color: #4CAF50;
}

.status.completed {
  color: #4CAF50;
}

.goods-container {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.goods-info text {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.total-info text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.total-price {
  color: #e64340 !important;
  font-weight: bold;
  font-size: 30rpx !important;
}

.pay-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-order image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-order text {
  font-size: 28rpx;
  color: #999;
}