/* ================= 0. 引入外部字体 ================= */
/* 采用 CSS 方式引入，避免 JS 严格的超时报错 */
.title {
  font-family: 'XinWei'; /* 直接用，手机电脑都能完美显示 */
  font-size: 60rpx;
}

/* 将原本 page 的背景色移到这里，解决控制台黄色警告 */
.home-page {
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
  background-color: #F4F7F6; 
}

/* ================= 1. 顶部渐变 Banner ================= */
.top-banner {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  display: flex;
  justify-content: center;
  padding-top: 90rpx; /* 稍微往上移一点点，给大字腾空间 */
  box-sizing: border-box;
}

.banner-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}


/* 主标题 */
.banner-text .title {
  font-size: 99rpx; /* 系统粗体字比较宽，字号可以稍微调小一点点防止换行 */
  font-weight: bold; /* 【恢复加粗】系统字体加粗非常有力量感 */
  color: #ffffff;
  margin-bottom: 20rpx; 
  letter-spacing: 4rpx; /* 字距稍微收敛一点 */
}

/* 副标题 */
.banner-text .subtitle {
  font-size: 35rpx; 
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx; 
}

/* ================= 2. 主体悬浮内容区 ================= */
.main-content {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
  margin-top: -140rpx; 
  position: relative;
  z-index: 10;
}

/* 两个大按钮横向排列 */
.action-row {
  display: flex;
  justify-content: space-between; 
  width: 100%;
  margin-bottom: 60rpx;
}

/* 单个按钮卡片 */
.action-btn {
  width: 47%; 
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06); 
}

/* 图标外面的淡绿色圆圈 */
.icon-box {
  width: 110rpx;
  height: 110rpx;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.action-icon {
  width: 56rpx !important;
  height: 56rpx !important;
  display: block;
}

.action-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* ================= 3. 最近识别区 ================= */
.history-section {
  width: 100%;
  padding-bottom: 40rpx;
}

.section-title-box {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.vertical-line {
  width: 8rpx;
  height: 32rpx;
  background: #4CAF50;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

/* ================= 4. 识别记录卡片相关样式 ================= */

/* 原有的空状态盒子基础样式 */
.history-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.03);
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 空状态卡片专属内边距 */
.empty-card {
  padding: 80rpx 0;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-img {
  width: 100rpx !important;
  height: 100rpx !important;
  opacity: 0.15;
  filter: grayscale(100%);
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 有数据的卡片样式 (新加) */
.data-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.03);
}

/* 卡片头部(始终显示) */
.card-header {
  display: flex;
  align-items: center;
}

/* 左侧拍照图片缩略图 */
.plant-thumb {
  width: 130rpx;
  height: 130rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background-color: #f5f7f5;
  flex-shrink: 0;
}

/* 中间基本信息 */
.basic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.plant-family {
  font-size: 26rpx;
  color: #666666;
}

/* 右侧箭头容器 */
.arrow-wrap {
  width: 60rpx;
  height: 130rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

/* 纯 CSS 绘制的箭头 */
.arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid #b2b2b2;
  border-bottom: 4rpx solid #b2b2b2;
  transition: transform 0.3s ease; /* 添加旋转动画过渡效果 */
}

/* 箭头向下 */
.arrow-down {
  transform: rotate(45deg);
}

/* 箭头向上 (展开状态) */
.arrow-up {
  transform: rotate(225deg);
}

/* 卡片详情区域(展开后显示) */
.card-body {
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #eeeeee;
}

.detail-block {
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.detail-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  /* 关键属性：保留文本内部的 \n 换行符 */
  white-space: pre-wrap; 
}
/* ================= 未登录提示卡片样式 ================= */
.login-prompt-card {
  display: flex;             /* 开启 Flex 布局 */
  flex-direction: column;    /* 让内部元素纵向排列 */
  align-items: center;       /* 强制内部元素【水平居中】！ */
  justify-content: center;   /* 垂直居中 */
  padding: 80rpx 0;          /* 上下留白 */
  width: 100%;               /* 撑满卡片宽度 */
  box-sizing: border-box;
}

/* 确保内部的盒子也保持居中 */
.login-prompt-card .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;       /* 强制内部文字和按钮水平居中 */
  width: 100%;
}

/* 🟢 修改点 1：提示文字完全按照图二的样式（浅灰、30rpx、下边距40rpx） */
.login-prompt-card .empty-text {
  font-size: 30rpx;          /* 从 26rpx 改大到图二的 30rpx */
  color: #999999;            /* 从深灰 #666 改为图二的浅灰 #999 */
  margin-bottom: 40rpx;      /* 距离底部按钮的间距从 30rpx 改为 40rpx */
  text-align: center;        /* 确保文字本身居中对齐 */
}

/* 🟢 修改点 2：登录按钮完全改成图二的绿色胶囊形状 */
.login-button {
  background-color: #07c160 !important; /* 强制改为微信主题绿（覆盖原来的 #f7f7f7 灰底） */
  color: #ffffff !important;            /* 强制改为纯白文字（覆盖原来的 #333 黑字） */
  width: 60% !important;                /* 宽度修改为图二的 60% */
  border-radius: 50rpx;                 /* 从小圆角 12rpx 改为大圆角（胶囊形状） 50rpx */
  font-size: 32rpx;                     /* 按钮字体大小 */
  font-weight: 500;                     /* 稍微去掉了原来厚重的 bold 加粗，更清爽 */
  
  /* 调整按钮的高度和内边距，使其更饱满 */
  height: auto;                         /* 去掉之前固定的 72rpx 高度 */
  line-height: normal;                  /* 重置行高 */
  padding: 20rpx 0;                     /* 用 padding 上下撑开按钮高度 */
  
  display: flex;
  justify-content: center;
  align-items: center;
}

.login-button::after {
  border: none;
}